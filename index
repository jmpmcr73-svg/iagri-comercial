    return {
      v:a.variable, lv:a.nivel,
      loc:a.estructura_nombre||'HidroExpo',
      val:parseFloat(a.valor_medido)||0,
      thr:parseFloat(a.valor_umbral)||0,
      msg:a.mensaje, ac:a.accion_recomendada||'-', ok:false
    };
  });
  // Solo reemplazar si hay datos reales
  if(extras.length>0)ALERTS_D=extras;
  buildAlerts();
  // Actualizar badge
  var criticas=extras.filter(function(a){return a.lv==='critico';}).length;
  var badge=document.getElementById('abadge');
  if(badge){badge.textContent='⚠ '+extras.length;badge.style.display='flex';}
}

// Cargar cuaderno desde Supabase
async function loadCuadernoFromSupa(){
  var data=await supaGet('v_cuaderno_completo?select=*&limit=50');
  if(!data||!data.length)return;
  CUA_D=data.map(function(r){
    return {
      zona:r.zona_id, struct:r.estructura_nombre||curSt.n,
      tipo:r.tipo_registro, cultivo:r.cultivo, variedad:r.variedad,
      tipo_s:r.tipo_siembra, dias_tp:r.dias_trasplante||0,
      fecha:r.fecha_siembra||r.fecha_trasplante||r.fecha_registro||'-',
      semana:r.semana_fenologica||0, estado:r.estado_zona||'-',
      notas:r.notas||'-', op:r.estructura_nombre||'-'
    };
  });
  buildCL();
}

// Cargar puntos IDW reales para mapa de calor
async function loadIDWFromSupa(estructuraId, variable, slot, z){
  var pts=await supaRpc('get_mediciones_idw',{
    p_estructura_id:estructuraId,
    p_variable:variable,
    p_slot:slot,
    p_z:z
  });
  return pts||[];
}

// Cargar stats de estructura desde Supabase
async function loadStatsFromSupa(estructuraId){
  var data=await supaRpc('get_estructura_stats',{
    p_estructura_id:estructuraId,
    p_slot:null, p_z:null
  });
  return data||null;
}

// Cargar robot log desde Supabase
async function loadRobotLogFromSupa(){
  var data=await supaGet('v_robot_log_completo?select=*&limit=20');
  if(!data||!data.length)return;
  // Actualizar contador de recorridos
  data.forEach(function(r){
    var k=r.estructura_nombre||'';
    if(!_RRC[k])_RRC[k]=0;
    _RRC[k]=Math.max(_RRC[k], parseInt(r.id)||0);
  });
}

// Llamar al iniciar la app para cargar datos reales
async function loadSupabaseData(){
  await Promise.all([
    loadKPIsFromSupa(),
    loadAlertasFromSupa(),
    loadCuadernoFromSupa(),
    loadRobotLogFromSupa()
  ]);
}





