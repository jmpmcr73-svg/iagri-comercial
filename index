function rnd(n){return(Math.random()-.5)*2*n;}
function hR(h){var m=/^#?([a-f\\\\d]{2})([a-f\\\\d]{2})([a-f\\\\d]{2})$/i.exec(h);return m?[parseInt(m[1],16),parseInt(m[2],16),parseInt(m[3],16)]:null;}
function gC(v,vk,a){
  a=a||.88;var c=VRS[vk];if(!c)return'#888';
  var t=Math.max(0,Math.min(1,(v-c.mn)/(c.mx-c.mn)));
  var cs=c.c,n=cs.length,sg=(n-1)*t,i=Math.min(Math.floor(sg),n-2),f=sg-i;
  var c1=hR(cs[i]),c2=hR(cs[i+1]);if(!c1||!c2)return'#888';
  return'rgba('+Math.round(c1[0]+f*(c2[0]-c1[0]))+','+Math.round(c1[1]+f*(c2[1]-c1[1]))+','+Math.round(c1[2]+f*(c2[2]-c1[2]))+','+a+')';
}
function idw(pts,gx,gy){var n=0,d=0;for(var i=0;i<pts.length;i++){var dx=gx-pts[i].x,dy=gy-pts[i].y,d2=dx*dx+dy*dy;if(d2<.01)return pts[i].v;var w=1/d2;n+=w*pts[i].v;d+=w;}return d?n/d:null;}
function avg(a){if(!a||!a.length)return 0;return a.reduce(function(s,v){return s+v;},0)/a.length;}
function gSt(v,vk){var c=VRS[vk];if(!c)return'ok';return(v>c.mx||v<c.mn)?'crit':(v>c.ox||v<c.on)?'warn':'ok';}
function sCl(s){return s==='crit'?'var(--cr)':s==='warn'?'var(--wn)':'var(--ok)';}
function fmt(v){return(+v).toFixed(v<1?3:1);}
function gM(slot,z,tipo,f){
  var k=(slot||3)+'-'+(z||'1.2')+'-'+(tipo||curTipo)+'-'+(f||curSt.f);
  if(MC[k])return MC[k];
  var base=SB[slot||3]||SB[3],zf=ZF[String(z)]||1,fi=f||curSt.f||7,xs=[1.8,5.2,16.3,19.7],pts=[];
  for(var r=1;r<=fi;r++){
    var yc=(r-1)*37+18,sf=Math.sin((r/fi)*Math.PI);
    for(var xi=0;xi<xs.length;xi++){
      var p={x:xs[xi]+rnd(.4),y:yc+rnd(3)};
      for(var vk in VRS)p[vk]=+(+(base[vk]||1)*zf+sf*3*(vk==='temp_aire'?1:-.3)+rnd((base[vk]||1)*.09)).toFixed(3);
      pts.push(p);
    }
  }
  MC[k]=pts;return pts;
}
function gZS(slot,z,tipo,f){
  var ms=gM(slot,z,tipo,f),fi=f||curSt.f||7,stats=[];
  for(var r=1;r<=fi;r++)for(var col=0;col<2;col++){
    var id=r+(col===0?'I':'D'),sub=ms.filter(function(m){return m.x>=(col===0?0:14.5)&&m.x<=(col===0?7:21.5)&&m.y>=(r-1)*37&&m.y<r*37;}),s={id:id};
    for(var vk in VRS){var vals=sub.map(function(m){return m[vk]||0;});s[vk+'_a']=avg(vals);s[vk+'_x']=vals.length?Math.max.apply(null,vals):0;s[vk+'_n']=vals.length?Math.min.apply(null,vals):0;}
    stats.push(s);
  }
  return stats;
}

