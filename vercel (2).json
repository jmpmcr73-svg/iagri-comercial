{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/comercial", "destination": "/comercial.html" },
    { "source": "/logistica", "destination": "/logistica.html" },
    { "source": "/agricola", "destination": "/agricola.html" },
    { "source": "/agroindustria", "destination": "/agroindustria.html" },
    { "source": "/finanzas", "destination": "/finanzas.html" },
    { "source": "/akasha", "destination": "/akasha.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Cache-Control", "value": "public, max-age=300, stale-while-revalidate=600" }
      ]
    }
  ],
  "env": {
